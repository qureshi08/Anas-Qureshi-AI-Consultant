# Copy to .env.local for local dev. Set the SAME variables in Vercel:
# Project -> Settings -> Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://hidqqawjhxafcavrjopg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret (full database access). NEVER commit it, NEVER expose it to
# the browser. Set it in .env.local locally and in Vercel env vars only.
SUPABASE_SERVICE_ROLE=your-service-role-secret

# AI assistant (Google Gemini, free tier). Get a free key at https://aistudio.google.com/apikey
# (no card needed). Server-only. Set it in Vercel env vars.
GEMINI_API_KEY=your-gemini-api-key
